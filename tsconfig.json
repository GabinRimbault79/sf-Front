{  
	"compilerOptions": {  
		"target": "ES2020",  
		"module": "ESNext",  
        "moduleResolution": "node",
        "esModuleInterop": true,
		"strict": false,  
		"allowJs": true,
        "jsx": "react-jsx",
        "noEmit": true,
        "skipLibCheck": true
	},  
	"include": ["src"],  
	"exclude": ["node_modules", "dist"]  
} 			 